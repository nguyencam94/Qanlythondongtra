rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'nguyencam94@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Households
    match /households/{householdId} {
      function isValidHousehold(data) {
        return data.keys().hasAll(['householdCode', 'ownerName', 'address', 'phone', 'notes'])
          && data.householdCode is string && data.householdCode.size() <= 100
          && data.ownerName is string && data.ownerName.size() <= 200
          && data.address is string && data.address.size() <= 500
          && data.phone is string && data.phone.size() <= 50
          && data.notes is string && data.notes.size() <= 5000;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidHousehold(request.resource.data);
      allow update: if isSignedIn() && isValidHousehold(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Members inside Household (Subcollection)
    match /households/{householdId}/members/{memberId} {
      function isValidMember(data) {
        return data.keys().hasAll(['householdId', 'fullName', 'relationship', 'birthDate', 'gender', 'residenceStatus', 'notes'])
          && data.householdId == householdId
          && data.fullName is string && data.fullName.size() <= 200
          && data.relationship is string && data.relationship.size() <= 100
          && data.birthDate is string && data.birthDate.size() <= 50
          && (data.gender == 'Nam' || data.gender == 'Nữ' || data.gender == 'Khác')
          && (data.residenceStatus == 'Có mặt tại địa phương' || data.residenceStatus == 'Đi làm ăn xa' || data.residenceStatus == 'Đã mất')
          && data.notes is string && data.notes.size() <= 1000;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMember(request.resource.data);
      allow update: if isSignedIn() && isValidMember(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Support Collection Group queries for members
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    // Fee Campaigns
    match /fee_campaigns/{campaignId} {
      function isValidCampaign(data) {
        return data.keys().hasAll(['title', 'description', 'type', 'amount'])
          && data.title is string && data.title.size() <= 200
          && data.description is string && data.description.size() <= 2000
          && (data.type == 'mandatory' || data.type == 'voluntary')
          && data.amount is number;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCampaign(request.resource.data);
      allow update: if isSignedIn() && isValidCampaign(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Fee Payments
    match /fee_payments/{paymentId} {
      function isValidPayment(data) {
        return data.keys().hasAll(['householdId', 'campaignId', 'status', 'paidAmount'])
          && data.householdId is string && data.householdId.size() <= 128
          && data.campaignId is string && data.campaignId.size() <= 128
          && (data.status == 'paid' || data.status == 'unpaid')
          && data.paidAmount is number
          && (!('notes' in data) || (data.notes is string && data.notes.size() <= 2000))
          && (!('paidAt' in data) || data.paidAt == null || data.paidAt is string || data.paidAt is timestamp);
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPayment(request.resource.data);
      allow update: if isSignedIn() && isValidPayment(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; 
    }
  }
}
